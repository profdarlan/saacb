# Django Configuration - PRODUCTION
SECRET_KEY=django-insecure-saacb-prod-change-me-in-deployment
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.51,saacb.lakeserver.online

# Database
DATABASE_URL=sqlite:////app/data/db.sqlite3

# SISGRU Integration (opcional)
SISGRU_USUARIO=
SISGRU_SENHA=
SISGRU_PRODUCAO=True

# Calculadora API
CALCULADORA_API_URL=http://planilha-calculos:8000
