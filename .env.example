# Django Configuration
SECRET_KEY=django-insecure-production-key-change-me
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.51,seu-dominio.com

# Database (SQLite padrão, mude para PostgreSQL em produção)
DATABASE_URL=sqlite:////app/data/db.sqlite3

# SISGRU Integration (opcional)
SISGRU_USUARIO=
SISGRU_SENHA=
SISGRU_PRODUCAO=False

# Calculadora API
CALCULADORA_API_URL=http://planilha-calculos:8000
CALCULADORA_API_TOKEN=

# Ollama AI (opcional)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3:8b

# SSL/HTTPS (mude para True após configurar HTTPS)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Email Configuration (opcional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@seu-dominio.com

# Docker Compose Ports
PORT=30010
CALCULADORA_PORT=8002

# PostgreSQL (opcional - usar com profile production)
POSTGRES_DB=saacb
POSTGRES_USER=saacb
POSTGRES_PASSWORD=mudar-senha-forte-aqui
